APP_ENV=development
PORT=3000
SKIP_AUTH=true
AI_PROVIDER=openrouter
PUBLIC_APP_URL=https://code-explainer.local
PUBLIC_APP_TITLE=Code Explainer

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
AUTH_CODES_TABLE=redeem_codes
AUTH_CODES_CODE_COLUMN=code
AUTH_CODES_PARTICIPANT_ID_COLUMN=participant_id
AUTH_CODES_USED_AT_COLUMN=used_at
AUTH_CODES_IS_USED_COLUMN=is_used
AUTH_PARTICIPANTS_TABLE=participants
AUTH_PARTICIPANTS_ID_COLUMN=id
AUTH_PARTICIPANTS_CODE_COLUMN=
AUTH_REFRESH_TOKENS_TABLE=refresh_tokens
AUTH_REFRESH_TOKENS_HASH_COLUMN=token_hash
AUTH_REFRESH_TOKENS_PARTICIPANT_ID_COLUMN=participant_id
AUTH_REFRESH_TOKENS_EXPIRES_AT_COLUMN=expires_at
AUTH_REFRESH_TOKENS_REVOKED_AT_COLUMN=revoked_at
AUTH_REFRESH_TOKENS_CREATED_AT_COLUMN=created_at
SESSIONS_TABLE=sessions
REQUEST_LOGS_TABLE=request_logs
