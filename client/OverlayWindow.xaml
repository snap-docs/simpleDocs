<Window x:Class="CodeExplainer.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Explanation"
        Width="480" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">

    <Border Background="#E8202020"
            CornerRadius="12"
            BorderBrush="#40FFFFFF"
            BorderThickness="1"
            Margin="8"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="4"
                              Opacity="0.5"
                              Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="✦ simpleDocs"
                           Foreground="#B0FFFFFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="CaseLabel"
                           Foreground="#80FFFFFF"
                           FontSize="10"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="0"
                       Height="1"
                       Fill="#20FFFFFF"
                       VerticalAlignment="Bottom"/>

            <!-- Content area -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Loading spinner -->
                <StackPanel x:Name="LoadingPanel"
                            Grid.RowSpan="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="⏳"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               Foreground="White">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" CenterX="12" CenterY="12"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="SpinnerRotation"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360"
                                            Duration="0:0:1.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="Thinking..."
                               Foreground="#80FFFFFF"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Streaming text output -->
                <ScrollViewer x:Name="ContentScroller"
                              Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <TextBlock x:Name="ResponseText"
                               Foreground="#EEFFFFFF"
                               FontSize="13"
                               FontFamily="Segoe UI, Inter"
                               LineHeight="20"
                               TextWrapping="Wrap"
                               Padding="4"/>
                </ScrollViewer>

                <Border x:Name="FeedbackPanel"
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="0,0,0,2"
                        Background="Transparent"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                    <DockPanel Margin="8,6,8,4">
                        <TextBlock Text="Was this helpful?"
                                   Foreground="#8AFFFFFF"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   DockPanel.Dock="Left"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                        <Button x:Name="ThumbsUpButton"
                                Click="ThumbsUpButton_Click"
                                Width="24"
                                Height="24"
                                Margin="0,0,8,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Helpful">
                            <TextBlock x:Name="ThumbsUpIcon"
                                       Text="👍"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#CCFFFFFF"
                                       Opacity="0.72"/>
                        </Button>

                        <Button x:Name="ThumbsDownButton"
                                Click="ThumbsDownButton_Click"
                                Width="24"
                                Height="24"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Not helpful">
                            <TextBlock x:Name="ThumbsDownIcon"
                                       Text="👎"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#CCFFFFFF"
                                       Opacity="0.72"/>
                        </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
