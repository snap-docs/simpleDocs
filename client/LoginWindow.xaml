<Window x:Class="CodeExplainer.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign In"
        Width="520"
        Height="470"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F7F8FB" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B7C0D2" />
        <SolidColorBrush x:Key="GlassStrokeBrush" Color="#5AFFFFFF" />
        <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D91A2233" Offset="0" />
            <GradientStop Color="#CC101723" Offset="0.55" />
            <GradientStop Color="#C4141B28" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#78B7FF" Offset="0" />
            <GradientStop Color="#4F7FFF" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="InputPanelBrush" Color="#FFF7FAFF" />
        <SolidColorBrush x:Key="InputStrokeBrush" Color="#7C9DFF" />
        <SolidColorBrush x:Key="InputHintBrush" Color="#6E7C92" />
        <SolidColorBrush x:Key="InputTextBrush" Color="#152033" />

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#08111E" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3EFFFFFF" />
            <Setter Property="Background" Value="#22FFFFFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#2BFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1DFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="#F7F8FB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseChrome" Property="Background" Value="#26FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseChrome" Property="Background" Value="#18FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="26"
                CornerRadius="24"
                Background="{StaticResource GlassPanelBrush}"
                BorderBrush="{StaticResource GlassStrokeBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="0"
                                  Color="#000000"
                                  Opacity="0.42" />
            </Border.Effect>

            <Grid ClipToBounds="True">
                <Ellipse Width="220"
                         Height="220"
                         Margin="-70,-110,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#2C8AA9FF"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="58" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="190"
                         Height="190"
                         Margin="0,0,-80,-70"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"
                         Fill="#166AE6C7"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="50" />
                    </Ellipse.Effect>
                </Ellipse>

                <Border Margin="1"
                        CornerRadius="23"
                        Background="#0DFFFFFF"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="1" />

                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="17"
                                    Background="#1DFFFFFF"
                                    BorderBrush="#28FFFFFF"
                                    BorderThickness="1">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="sd"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>

                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="simpleDocs"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Secure sign in"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click"
                                Content="×" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="10,5"
                                HorizontalAlignment="Left"
                                Background="#1FFFFFFF"
                                BorderBrush="#2AFFFFFF"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock Text="One-time access"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#D9E9FF" />
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Margin="0,18,0,0"
                                   Text="Enter your access code"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,10,0,0"
                                   MaxWidth="390"
                                   Text="Sign in once and the app will keep you authenticated for 30 days on this device."
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <TextBlock Grid.Row="3"
                                   Margin="2,18,0,0"
                                   Text="Access code"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#D9E9FF" />

                        <Border Grid.Row="4"
                                Margin="0,10,0,0"
                                Padding="0"
                                Background="{StaticResource InputPanelBrush}"
                                BorderBrush="{StaticResource InputStrokeBrush}"
                                BorderThickness="2"
                                CornerRadius="18"
                                Cursor="IBeam">
                            <Grid Height="66"
                                  MouseLeftButtonDown="CodeInputHost_MouseLeftButtonDown"
                                  Cursor="IBeam">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Margin="10"
                                        CornerRadius="13"
                                        Background="#E8EEF8"
                                        BorderBrush="#D4DEED"
                                        BorderThickness="1">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="ID"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#43526A" />
                                </Border>

                                <Grid Grid.Column="1"
                                      Margin="0,0,16,0">
                                    <TextBox x:Name="CodeTextBox"
                                             Height="66"
                                             Padding="0,0,0,0"
                                             FontSize="28"
                                             FontWeight="SemiBold"
                                             Background="Transparent"
                                             Foreground="{StaticResource InputTextBrush}"
                                             BorderThickness="0"
                                             CaretBrush="#9AC6FF"
                                             VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Left"
                                             Cursor="IBeam"
                                             TextChanged="CodeTextBox_TextChanged" />

                                    <TextBlock x:Name="PlaceholderText"
                                               Margin="0,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Type your code here"
                                               FontSize="18"
                                               Foreground="{StaticResource InputHintBrush}"
                                               IsHitTestVisible="False" />
                                </Grid>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="5"
                                   Margin="2,12,0,0"
                                   Text="Click inside the white box, then paste or type the code exactly as you received it."
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />

                        <TextBlock x:Name="ErrorText"
                                   Grid.Row="6"
                                   Margin="2,12,0,0"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="#FFB6A8"
                                   Visibility="Collapsed" />
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="BusyText"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#D8E6FF"
                                   Visibility="Collapsed"
                                   Text="Signing in..." />

                        <Button x:Name="CancelButton"
                                Grid.Column="1"
                                Width="118"
                                Height="44"
                                Margin="12,0,0,0"
                                Click="CancelButton_Click"
                                Content="Cancel"
                                Style="{StaticResource SecondaryButtonStyle}" />

                        <Button x:Name="SignInButton"
                                Grid.Column="2"
                                Width="132"
                                Height="44"
                                Margin="12,0,0,0"
                                Click="SignInButton_Click"
                                Content="Continue"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
