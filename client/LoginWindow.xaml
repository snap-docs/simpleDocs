<Window x:Class="CodeExplainer.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign In"
        Width="420"
        Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#171717">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Enter your access code"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#F2F2F2"/>

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   Text="You only need to do this once. The app will keep you signed in for 30 days."
                   TextWrapping="Wrap"
                   Foreground="#C8C8C8"/>

        <TextBox x:Name="CodeTextBox"
                 Grid.Row="2"
                 Margin="0,18,0,0"
                 Height="38"
                 Padding="10,8"
                 FontSize="16"
                 Background="#242424"
                 Foreground="#F6F6F6"
                 BorderBrush="#3F3F3F"
                 BorderThickness="1"/>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="3"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   Foreground="#FF9A8A"
                   Visibility="Collapsed"/>

        <DockPanel Grid.Row="4"
                   Margin="0,18,0,0">
            <TextBlock x:Name="BusyText"
                       Foreground="#C8C8C8"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"
                       DockPanel.Dock="Left"
                       Text="Signing in..."/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Width="90"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"
                        Content="Cancel"/>
                <Button x:Name="SignInButton"
                        Width="110"
                        Height="34"
                        Click="SignInButton_Click"
                        Content="Sign In"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
